{
  "name": "minecraft-server-ondemand",
  "version": "0.1.0",
  "scripts": {
    "typecheck": "tsc",
    "build": "pnpm run typecheck && esbuild bin/app.ts --bundle --platform=node --target=node24 --outfile=dist/app.js --sourcemap --external:aws-cdk-lib --external:aws-cdk-lib/* --external:constructs",
    "watch": "tsc -w",
    "test": "jest",
    "synth": "pnpm run build && cdk synth",
    "deploy": "pnpm run build && cdk deploy --all",
    "destroy": "cdk destroy --all",
    "cdk": "cdk",
    "server:start": "bash scripts/server-power.sh start",
    "server:stop": "bash scripts/server-power.sh stop",
    "discord:register-commands": "bash scripts/register-discord-commands.sh",
    "discord:set-interactions-url": "bash scripts/set-discord-interactions-url.sh",
    "import:files": "bash scripts/import-server-files.sh"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1128.1",
    "esbuild": "^0.28.1",
    "jest": "^30",
    "ts-jest": "^29",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-cost-explorer": "^3.1075.0",
    "@aws-sdk/client-ec2": "^3.1075.0",
    "@aws-sdk/client-lambda": "^3.1075.0",
    "@aws-sdk/client-ssm": "^3.1075.0",
    "aws-cdk-lib": "^2.260.0",
    "constructs": "^10.5.0",
    "tweetnacl": "^1.0.3"
  }
}
